{
  "name": "facturacion-cfdi",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Sistema de facturación CFDI 4.0 para negocio familiar",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -k -n api,web -c blue,magenta \"npm run api:dev\" \"npm run dev\"",
    "postinstall": "npm install --prefix server",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "api": "npm start --prefix server",
    "api:dev": "npm run dev --prefix server"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^10.0.3",
    "eslint": "^9.9.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "vite": "^5.4.1"
  },
  "keywords": ["cfdi", "facturacion", "sat", "react", "vite", "mexico"],
  "author": "Victor",
  "license": "MIT"
}